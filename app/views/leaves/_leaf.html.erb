<li class="arrangement__item toc__leaf toc__leaf--<%= leaf.leafable_name %> <%= local_assigns[:css_class] %>" id="<%= dom_id(leaf) %>" data-arrangement-target="item" data-id="<%= leaf.id %>">
  <%= image_tag "handle.svg", aria: { hidden: true }, size: 24, class: "arrangement__handle translucent colorize--black" %>

  <div class="toc__thumbnail">
    <%= link_to leafable_path(leaf), class: "toc__link", data: { turbo_frame: "_top" } do %>
      <span class="for-screen-reader">Open <%= leaf.title %></span>
    <% end %>

    <%= leaf.title if leaf.leafable.is_a?(Section) %>

    <%= leaf.leafable.body.to_html if leaf.leafable.is_a?(Page) %>

    <% if leaf.leafable.is_a?(Picture) %>
      <%= image_tag leaf.leafable.image.attached? ? leaf.leafable.image.variant(:large) : "default-picture.webp" %>
    <% end %>
  </div>

  <%= link_to leafable_path(leaf), class: "toc__title min-width", data: { turbo_frame: "_top" } do %>
    <span class="overflow-ellipsis"><%= leaf.title %></span>
  <% end %>

  <small class="toc__wordcount translucent txt-small--responsive">
    <% if leaf.leafable.is_a?(Page) %>
      <%= word_count(leaf.leafable.body.content) %>
    <% end %>
  </small>

  <%= yield if block_given? %>
</li>
