# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should come from ENV, files, or a password
# manager. Do not put raw credentials in this file.

# Improve security by using a password manager. Never check config/master.key into git.
RAILS_MASTER_KEY=$(cat config/master.key 2>/dev/null || true)

# Writebook secrets: read from local .env.kamal.local for deploy convenience.
SECRET_KEY_BASE=$(sed -n 's/^SECRET_KEY_BASE=//p' .env.kamal.local 2>/dev/null | head -n 1)

# Custom TLS certs for Kamal proxy can be read from the server over SSH.
# Keep certbot state on server so ephemeral dev environments can deploy safely.
KAMAL_SSL_CERTIFICATE_PEM=$(ssh -F /dev/null kdlocpanda@10.10.10.106 'cat /home/kdlocpanda/.config/letsencrypt/live/admin.joshyorko.com/fullchain.pem')
KAMAL_SSL_PRIVATE_KEY_PEM=$(ssh -F /dev/null kdlocpanda@10.10.10.106 'cat /home/kdlocpanda/.config/letsencrypt/live/admin.joshyorko.com/privkey.pem')

# Cloudflare Tunnel token for the cloudflared accessory.
CLOUDFLARED_TOKEN=$(sed -n 's/^CLOUDFLARED_TOKEN=//p' .env.kamal.local 2>/dev/null | head -n 1)
